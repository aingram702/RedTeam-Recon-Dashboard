{
  "manifest_version": 3,
  "name": "RedTeam Recon Dashboard",
  "version": "1.0.0",
  "description": "Aggregates WHOIS/RDAP, DNS, technology fingerprint, and exposed ports for the current site. For authorized reconnaissance only.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "https://rdap.org/*",
    "https://cloudflare-dns.com/*",
    "https://internetdb.shodan.io/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "RedTeam Recon Dashboard",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
